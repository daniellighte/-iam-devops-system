# ── Application ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── JWT (never commit real values) ───────────────────────
JWT_SECRET=replace-with-min-32-char-random-string
JWT_REFRESH_SECRET=replace-with-different-min-32-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=iam-system
JWT_AUDIENCE=iam-clients

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/iam_dev

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

